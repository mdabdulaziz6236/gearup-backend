model User {
  id           String     @id @default(uuid())
  fullName     String
  email        String     @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  gears        GearItem[]    @relation("ProviderGears")
  rentalOrders RentalOrder[] @relation("CustomerOrders")
  reviews      Review[]      @relation("CustomerReviews")

  @@map("users")
}
